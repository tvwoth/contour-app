# internal application port (flask/gunicorn listens here)
# this file is used as a template during install;
# the real `.env` is created once and then left untouched.
APP_PORT=5000
HOST_HTTP_PORT=80

# password for saving/deleting/renaming user configurations (default: admin)
CONFIG_ADMIN_PASSWORD=admin

# flask session signing key (generated automatically during install)
# SECRET_KEY=
